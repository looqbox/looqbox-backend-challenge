        <mxCell id="controller" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="&lt;b&gt;PokemonController&lt;/b&gt;&lt;br&gt;@RestController · @RequestMapping(&quot;/pokemons&quot;)&lt;br&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;GET /pokemons?query&amp;amp;sort  →  PokemonListResponse&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;GET /pokemons/highlight?query&amp;amp;sort  →  PokemonHighlightResponse&lt;/span&gt;&lt;/div&gt;" vertex="1">
